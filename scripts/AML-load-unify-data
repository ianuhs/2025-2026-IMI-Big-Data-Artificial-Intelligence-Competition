txn['customer_id'].nunique():,}\")\n","    print()\n","\n","    # ═════════════════════════════════════════════════════════════\n","    # BASIC VOLUME & VELOCITY FEATURES\n","    # ═════════════════════════════════════════════════════════════\n","\n","    print(\"Computing volume & velocity features...\")\n","\n","    # Split debits and credits\n","    debits = df_txn[df_txn['debit_credit'] == 'D'].copy()\n","    credits = df_txn[df_txn['debit_credit'] == 'C'].copy()\n","\n","    # Main aggregations\n","    features = df_txn.groupby('customer_id').agg({\n","        'amount_cad': ['count', 'sum', 'mean', 'median', 'std', 'min', 'max'],\n","        'transaction_datetime': ['min', 'max']\n","    })\n","\n","    # Flatten multi-level columns\n","    features.columns = ['_'.join(col).strip() for col in features.columns.values]\n","    features = features.reset_index()\n","\n","    # Rename for clarity\n","    features.columns = [\n","        'customer_id',\n","        'transaction_count_total',\n","        'total_volume',\n","        'avg_transaction_amount',\n","        'median_transaction_amount',\n","        'std_transaction_amount',\n","        'min_transaction_amount',\n","        'max_transaction_amount',\n","        'first_transaction_date',\n","        'last_transaction_date'\n","    ]\n","\n","    # Debit aggregations\n","    debit_agg = debits.groupby('customer_id').agg({\n","        'amount_cad': ['count', 'sum']\n","    }).reset_index()\n","    debit_agg.columns = ['customer_id', 'transaction_count_debit', 'total_outflow']\n","\n","    # Credit aggregations\n","    credit_agg = credits.groupby('customer_id').agg({\n","        'amount_cad': ['count', 'sum']\n","    }).reset_index()\n","    credit_agg.columns = ['customer_id', 'transaction_count_credit', 'total_inflow']\n","\n","    # Merge all\n","    features = features.merge(debit_agg, on='customer_id', how='left')\n","    features = features.merge(credit_agg, on='customer_id', how='left')\n","\n","    # Fill missing values\n","    features['transaction_count_debit'] = features['transaction_count_debit'].fillna(0)\n","    features['transaction_count_credit'] = features['transaction_count_credit'].fillna(0)\n","    features['total_outflow'] = features['total_outflow'].fillna(0)\n","    features['total_inflow'] = features['total_inflow'].fillna(0)\n","\n","    # Derived features\n","    features['net_flow'] = features['total_inflow'] - features['total_outflow']\n","    features['inflow_outflow_ratio'] = features['total_inflow'] / (features['total_outflow'] + 1)\n","    features['amount_cv'] = features['std_transaction_amount'] / (features['avg_transaction_amount'] + 1)\n","\n","    # Time-based features\n","    features['first_transaction_date'] = pd.to_datetime(features['first_transaction_date'])\n","    features['last_transaction_date'] = pd.to_datetime(features['last_transaction_date'])\n","    features['time_span_days'] = (features['last_transaction_date'] - features['first_transaction_date']).dt.days + 1\n","    features['transactions_per_day'] = features['transaction_count_total'] / features['time_span_days']\n","    features['volume_per_day'] = features['total_volume'] / features['time_span_days']\n","    features['inflow_per_day'] = features['total_inflow'] / features['time_span_days']\n","    features['outflow_per_day'] = features['total_outflow'] / features['time_span_days']\n","\n","    print(f\"Created {features.shape[1] - 1} volume & velocity features\")\n","\n","    # ═════════════════════════════════════════════════════════════\n","    # STRUCTURING DETECTION FEATURES\n","    # ═════════════════════════════════════════════════════════════\n","\n","    print(\"Computing structuring detection features...\")\n","\n","    # Transactions below $10K\n","    below_10k = df_txn[df_txn['amount_cad'] < 10000].groupby('customer_id').agg({\n","        'amount_cad': ['count', 'sum']\n","    }).reset_index()\n","    below_10k.columns = ['customer_id', 'count_below_10k', 'sum_below_10k']\n","    features = features.merge(below_10k, on='customer_id', how='left')\n","    features['count_below_10k'] = features['count_below_10k'].fillna(0)\n","    features['sum_below_10k'] = features['sum_below_10k'].fillna(0)\n","    features['ratio_below_10k'] = features['count_below_10k'] / features['transaction_count_total']\n","\n","    # Near $10K threshold (9000-9999) - classic structuring\n","    near_10k = df_txn[\n","        (df_txn['amount_cad'] >= 9000) & (df_txn['amount_cad'] < 10000)\n","    ].groupby('customer_id').size().reset_index(name='count_near_10k')\n","    features = features.merge(near_10k, on='customer_id', how='left')\n","    features['count_near_10k'] = features['count_near_10k'].fillna(0)\n","\n","    # Very close to $10K (9800-9999)\n","    very_near_10k = df_txn[\n","        (df_txn['amount_cad'] >= 9800) & (df_txn['amount_cad'] < 10000)\n","    ].groupby('customer_id').size().reset_index(name='count_very_near_10k')\n","    features = features.merge(very_near_10k, on='customer_id', how='left')\n","    features['count_very_near_10k'] = features['count_very_near_10k'].fillna(0)\n","\n","    # Round amounts (awareness of reporting)\n","    round_100 = df_txn[df_txn['amount_cad'] % 100 == 0].groupby('customer_id').size().reset_index(name='count_round_100')\n","    features = features.merge(round_100, on='customer_id', how='left')\n","    features['count_round_100'] = features['count_round_100'].fillna(0)\n","    features['ratio_round_100'] = features['count_round_100'] / features['transaction_count_total']\n","\n","    # Round to $1000\n","    round_1000 = df_txn[df_txn['amount_cad'] % 1000 == 0].groupby('customer_id').size().reset_index(name='count_round_1000')\n","    features = features.merge(round_1000, on='customer_id', how='left')\n","    features['count_round_1000'] = features['count_round_1000'].fillna(0)\n","    features['ratio_round_1000'] = features['count_round_1000'] / features['transaction_count_total']\n","\n","    # Geographic diversity (location hopping)\n","    geo_diversity = df_txn.groupby('customer_id').agg({\n","        'country': 'nunique',\n","        'province': 'nunique',\n","        'city': 'nunique'\n","    }).reset_index()\n","    geo_diversity.columns = ['customer_id', 'unique_countries', 'unique_provinces', 'unique_cities']\n","    features = features.merge(geo_diversity, on='customer_id', how='left')\n","    features['avg_txn_per_city'] = features['transaction_count_total'] / (features['unique_cities'] + 0.1)\n","    features['avg_txn_per_province'] = features['transaction_count_total'] / (features['unique_provinces'] + 0.1)\n","\n","    print(f\"Total features so far: {features.shape[1] - 1}\")\n","\n","    # ═════════════════════════════════════════════════════════════\n","    # CHANNEL-SPECIFIC FEATURES\n","    # ═════════════════════════════════════════════════════════════\n","\n","    print(\"Computing channel-specific features...\")\n","\n","    # Channel counts and sums\n","    channel_agg = df_txn.groupby(['customer_id', 'channel']).agg({\n","        'amount_cad': ['count', 'sum', 'mean']\n","    }).reset_index()\n","\n","    # Flatten columns\n","    channel_agg.columns = ['customer_id', 'channel', 'count', 'sum', 'mean']\n","\n","    # Pivot for counts\n","    channel_count_pivot = channel_agg.pivot(\n","        index='customer_id',\n","        columns='channel',\n","        values='count'\n","    ).reset_index()\n","    channel_count_pivot.columns = ['customer_id'] + [f'count_{col.lower()}' for col in channel_count_pivot.columns[1:]]\n","\n","    # Pivot for sums\n","    channel_sum_pivot = channel_agg.pivot(\n","        index='customer_id',\n","        columns='channel',\n","        values='sum'\n","    ).reset_index()\n","    channel_sum_pivot.columns = ['customer_id'] + [f'sum_{col.lower()}' for col in channel_sum_pivot.columns[1:]]\n","\n","    # Pivot for averages\n","    channel_avg_pivot = channel_agg.pivot(\n","        index='customer_id',\n","        columns='channel',\n","        values='mean'\n","    ).reset_index()\n","    channel_avg_pivot.columns = ['customer_id'] + [f'avg_{col.lower()}' for col in channel_avg_pivot.columns[1:]]\n","\n","    # Merge all channel features\n","    features = features.merge(channel_count_pivot, on='customer_id', how='left')\n","    features = features.merge(channel_sum_pivot, on='customer_id', how='left')\n","    features = features.merge(channel_avg_pivot, on='customer_id', how='left')\n","\n","    # Fill NaN for channels (customer didn't use that channel)\n","    channel_cols = [c for c in features.columns if any(x in c.lower() for x in ['_abm', '_card', '_cheque', '_eft', '_emt', '_westernunion', '_wire'])]\n","    for col in channel_cols:\n","        features[col] = features[col].fillna(0)\n","\n","    # Channel diversity\n","    channel_diversity = df_txn.groupby('customer_id')['channel'].nunique().reset_index(name='unique_channels')\n","    features = features.merge(channel_diversity, on='customer_id', how='left')\n","    features['channel_diversity'] = features['unique_channels'] / 7  # Normalized to 0-1\n","\n","    # Channel concentration (Herfindahl index)\n","    channel_concentration = df_txn.groupby(['customer_id', 'channel']).size().reset_index(name='channel_txn_count')\n","    channel_concentration['total_txns'] = channel_concentration.groupby('customer_id')['channel_txn_count'].transform('sum')\n","    channel_concentration['channel_share'] = channel_concentration['channel_txn_count'] / channel_concentration['total_txns']\n","    channel_concentration['channel_share_sq'] = channel_concentration['channel_share'] ** 2\n","    channel_hhi = channel_concentration.groupby('customer_id')['channel_share_sq'].sum().reset_index(name='channel_concentration_hhi')\n","    features = features.merge(channel_hhi, on='customer_id', how='left')\n","\n","    # Cash transactions (if column exists)\n","    if 'cash_indicator' in df_txn.columns:\n","        cash_agg = df_txn[df_txn['cash_indicator'] == 1].groupby('customer_id').agg({\n","            'amount_cad': ['count', 'sum']\n","        }).reset_index()\n","        cash_agg.columns = ['customer_id', 'cash_transaction_count', 'cash_transaction_sum']\n","        features = features.merge(cash_agg, on='customer_id', how='left')\n","        features['cash_transaction_count'] = features['cash_transaction_count'].fillna(0)\n","        features['cash_transaction_sum'] = features['cash_transaction_sum'].fillna(0)\n","        features['cash_ratio'] = features['cash_transaction_count'] / features['transaction_count_total']\n","    else:\n","        features['cash_transaction_count'] = 0\n","        features['cash_transaction_sum'] = 0\n","        features['cash_ratio'] = 0\n","\n","    # E-commerce (if column exists)\n","    if 'ecommerce_ind' in df_txn.columns:\n","        ecom_agg = df_txn[df_txn['ecommerce_ind'] == 1].groupby('customer_id').size().reset_index(name='ecommerce_count')\n","        features = features.merge(ecom_agg, on='customer_id', how='left')\n","        features['ecommerce_count'] = features['ecommerce_count'].fillna(0)\n","        features['ecommerce_ratio'] = features['ecommerce_count'] / features['transaction_count_total']\n","    else:\n","        features['ecommerce_count'] = 0\n","        features['ecommerce_ratio'] = 0\n","\n","    print(f\"Total features so far: {features.shape[1] - 1}\")\n","\n","    # ═════════════════════════════════════════════════════════════\n","    # GEOGRAPHIC RISK FEATURES\n","    # ═════════════════════════════════════════════════════════════\n","\n","    print(\"Computing geographic risk features...\")\n","\n","    # Define high-risk jurisdictions\n","    DRUG_COUNTRIES = ['MX', 'CO', 'PE', 'BO', 'VE', 'GT', 'HN', 'EC', 'BR']\n","    HIGH_RISK_FATF = ['KP', 'IR', 'MM']  # North Korea, Iran, Myanmar\n","    GREYLIST = ['AL', 'BB', 'BF', 'KH', 'HR', 'JM', 'JO', 'ML', 'MZ', 'NI', 'PK', 'PA', 'PH', 'SN', 'SY', 'TZ', 'TR', 'UG', 'AE', 'VN', 'YE']\n","    OFFSHORE = ['KY', 'BM', 'VG', 'PA', 'LI', 'MC', 'AD', 'BS', 'LU']\n","\n","    # Drug-producing/transit countries\n","    drug_txns = df_txn[df_txn['country'].isin(DRUG_COUNTRIES)].groupby('customer_id').agg({\n","        'amount_cad': ['count', 'sum']\n","    }).reset_index()\n","    drug_txns.columns = ['customer_id', 'drug_country_txn_count', 'drug_country_txn_sum']\n","    features = features.merge(drug_txns, on='customer_id', how='left')\n","    features['drug_country_txn_count'] = features['drug_country_txn_count'].fillna(0)\n","    features['drug_country_txn_sum'] = features['drug_country_txn_sum'].fillna(0)\n","\n","    # FATF high-risk\n","    highrisk_txns = df_txn[df_txn['country'].isin(HIGH_RISK_FATF)].groupby('customer_id').size().reset_index(name='high_risk_fatf_txn_count')\n","    features = features.merge(highrisk_txns, on='customer_id', how='left')\n","    features['high_risk_fatf_txn_count'] = features['high_risk_fatf_txn_count'].fillna(0)\n","\n","    # FATF greylist\n","    greylist_txns = df_txn[df_txn['country'].isin(GREYLIST)].groupby('customer_id').size().reset_index(name='greylist_txn_count')\n","    features = features.merge(greylist_txns, on='customer_id', how='left')\n","    features['greylist_txn_count'] = features['greylist_txn_count'].fillna(0)\n","\n","    # Offshore centers\n","    offshore_txns = df_txn[df_txn['country'].isin(OFFSHORE)].groupby('customer_id').size().reset_index(name='offshore_center_txn_count')\n","    features = features.merge(offshore_txns, on='customer_id', how='left')\n","    features['offshore_center_txn_count'] = features['offshore_center_txn_count'].fillna(0)\n","\n","    # International transactions (not Canada)\n","    intl_txns = df_txn[df_txn['country'] != 'CA'].groupby('customer_id').agg({\n","        'amount_cad': ['count', 'sum']\n","    }).reset_index()\n","    intl_txns.columns = ['customer_id', 'international_txn_count', 'international_txn_sum']\n","    features = features.merge(intl_txns, on='customer_id', how='left')\n","    features['international_txn_count'] = features['international_txn_count'].fillna(0)\n","    features['international_txn_sum'] = features['international_txn_sum'].fillna(0)\n","    features['international_ratio'] = features['international_txn_count'] / features['transaction_count_total']\n","\n","    # Any high-risk flag\n","    features['has_any_high_risk_txn'] = (\n","        (features['drug_country_txn_count'] > 0) |\n","        (features['high_risk_fatf_txn_count'] > 0) |\n","        (features['offshore_center_txn_count'] > 0)\n","    ).astype(int)\n","\n","    print(f\"Total features so far: {features.shape[1] - 1}\")\n","\n","    # ═════════════════════════════════════════════════════════════\n","    # TEMPORAL PATTERN FEATURES\n","    # ═════════════════════════════════════════════════════════════\n","\n","    print(\"Computing temporal pattern features...\")\n","\n","    # Night transactions (12am-6am)\n","    if 'time_of_day' in df_txn.columns:\n","        night_txns = df_txn[df_txn['time_of_day'] == 'Night'].groupby('customer_id').size().reset_index(name='night_transaction_count')\n","        features = features.merge(night_txns, on='customer_id', how='left')\n","        features['night_transaction_count'] = features['night_transaction_count'].fillna(0)\n","        features['night_transaction_ratio'] = features['night_transaction_count'] / features['transaction_count_total']\n","    elif 'hour' in df_txn.columns:\n","        night_txns = df_txn[(df_txn['hour'] >= 0) & (df_txn['hour'] <= 5)].groupby('customer_id').size().reset_index(name='night_transaction_count')\n","        features = features.merge(night_txns, on='customer_id', how='left')\n","        features['night_transaction_count'] = features['night_transaction_count'].fillna(0)\n","        features['night_transaction_ratio'] = features['night_transaction_count'] / features['transaction_count_total']\n","\n","    # Weekend transactions\n","    if 'day_of_week' in df_txn.columns:\n","        weekend_txns = df_txn[df_txn['day_of_week'].isin([5, 6])].groupby('customer_id').size().reset_index(name='weekend_transaction_count')\n","        features = features.merge(weekend_txns, on='customer_id', how='left')\n","        features['weekend_transaction_count'] = features['weekend_transaction_count'].fillna(0)\n","        features['weekend_ratio'] = features['weekend_transaction_count'] / features['transaction_count_total']\n","\n","    # Hour regularity (are transactions at the same hour? = scripted)\n","    if 'hour' in df_txn.columns:\n","        hour_regularity = df_txn.groupby(['customer_id', 'hour']).size().reset_index(name='hour_count')\n","        hour_max = hour_regularity.groupby('customer_id')['hour_count'].max().reset_index(name='max_same_hour_count')\n","        features = features.merge(hour_max, on='customer_id', how='left')\n","        features['hour_regularity_score'] = features['max_same_hour_count'] / features['transaction_count_total']\n","\n","    # Day of week regularity\n","    if 'day_of_week' in df_txn.columns:\n","        dow_regularity = df_txn.groupby(['customer_id', 'day_of_week']).size().reset_index(name='dow_count')\n","        dow_max = dow_regularity.groupby('customer_id')['dow_count'].max().reset_index(name='max_same_dow_count')\n","        features = features.merge(dow_max, on='customer_id', how='left')\n","        features['dow_regularity_score'] = features['max_same_dow_count'] / features['transaction_count_total']\n","\n","    print(f\"Total features so far: {features.shape[1] - 1}\")\n","\n","    # ═════════════════════════════════════════════════════════════\n","    # BEHAVIORAL DRIFT FEATURES\n","    # ═════════════════════════════════════════════════════════════\n","\n","    print(\"Computing behavioral drift features...\")\n","\n","    # Monthly aggregations for drift detection\n","    if 'year_month' in df_txn.columns:\n","        monthly_agg = df_txn.groupby(['customer_id', 'year_month']).agg({\n","            'amount_cad': ['count', 'sum']\n","        }).reset_index()\n","        monthly_agg.columns = ['customer_id', 'year_month', 'monthly_txn_count', 'monthly_volume']\n","\n","        # Calculate variance/std across months (high variance = unstable behavior)\n","        monthly_stats = monthly_agg.groupby('customer_id').agg({\n","            'monthly_txn_count': ['std', 'mean'],\n","            'monthly_volume': ['std', 'mean']\n","        }).reset_index()\n","        monthly_stats.columns = ['customer_id',\n","                                 'monthly_txn_count_std', 'monthly_txn_count_mean',\n","                                 'monthly_volume_std', 'monthly_volume_mean']\n","\n","        # Coefficient of variation (normalized volatility)\n","        monthly_stats['monthly_txn_cv'] = monthly_stats['monthly_txn_count_std'] / (monthly_stats['monthly_txn_count_mean'] + 1)\n","        monthly_stats['monthly_volume_cv'] = monthly_stats['monthly_volume_std'] / (monthly_stats['monthly_volume_mean'] + 1)\n","\n","        features = features.merge(monthly_stats, on='customer_id', how='left')\n","        features['monthly_txn_count_std'] = features['monthly_txn_count_std'].fillna(0)\n","        features['monthly_volume_std'] = features['monthly_volume_std'].fillna(0)\n","        features['monthly_txn_cv'] = features['monthly_txn_cv'].fillna(0)\n","        features['monthly_volume_cv'] = features['monthly_volume_cv'].fillna(0)\n","\n","    print(f\"Total features so far: {features.shape[1] - 1}\")\n","\n","    print(\"\\n7️Final cleanup...\")\n","\n","    # Replace any infinities with NaN, then fill\n","    features = features.replace([np.inf, -np.inf], np.nan)\n","\n","    # Fill any remaining NaN with 0 (for count features) or median (for ratio features)\n","    for col in features.columns:\n","        if col == 'customer_id':\n","            continue\n","        if features[col].isnull().sum() > 0:\n","            if 'ratio' in col or 'cv' in col or 'diversity' in col:\n","                features[col] = features[col].fillna(features[col].median())\n","            else:\n","                features[col] = features[col].fillna(0)\n","\n","    print(f\"Cleaned {features.shape[1] - 1} features\")\n","\n","    print(\"\\n\" + \"=\"*70)\n","    print(\"FEATURE ENGINEERING COMPLETE!\")\n","    print(\"=\"*70)\n","    print(f\"   Customers: {len(features):,}\")\n","    print(f\"   Total features: {features.shape[1] - 1}\")\n","    print()\n","\n","    return features"],"metadata":{"id":"VyCPB_goKIYL","executionInfo":{"status":"ok","timestamp":1771693255455,"user_tz":300,"elapsed":39,"user":{"displayName":"Cindy Qiao","userId":"14163798394007060084"}}},"execution_count":8,"outputs":[]},{"cell_type":"code","source":["print()\n","\n","# Run vectorized feature engineering\n","df_features = engineer_features_vectorized(\n","    df_transactions,\n","    df_kyc_individual,\n","    df_kyc_business\n",")\n","\n","print(\"\\nFeature engineering complete!\")\n","print(f\"   Shape: {df_features.shape}\")\n","print(f\"\\nSample of features:\")\n","print(df_features.head())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4wcMHKheMPzj","executionInfo":{"status":"ok","timestamp":1771693286215,"user_tz":300,"elapsed":30761,"user":{"displayName":"Cindy Qiao","userId":"14163798394007060084"}},"outputId":"e7b5d823-8883-43e1-b688-3f9974e0652b"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Starting feature engineering...\n","   Transactions to process: 5,903,333\n","   Customers to process: 61,410\n","\n","Computing volume & velocity features...\n","Created 21 volume & velocity features\n","Computing structuring detection features...\n","Total features so far: 35\n","Computing channel-specific features...\n","Total features so far: 64\n","Computing geographic risk features...\n","Total features so far: 73\n","Computing temporal pattern features...\n","Total features so fa