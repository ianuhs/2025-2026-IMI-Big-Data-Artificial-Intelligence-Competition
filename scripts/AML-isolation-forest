65:\n","        print(f\"   FAIR - Model shows some ability to detect suspicious customers\")\n","    elif roc_auc >= 0.55:\n","        print(f\"   POOR - Model barely better than random\")\n","    else:\n","        print(f\"   RANDOM - Model is not learning meaningful patterns\")\n","\n","    # Compare risk scores between clean and suspicious\n","    labeled_results = results_df[labeled_mask].copy()\n","    clean_scores = labeled_results[labeled_results['actual_label'] == 0]['risk_score']\n","    susp_scores = labeled_results[labeled_results['actual_label'] == 1]['risk_score']\n","\n","    print(f\"\\n Risk Score Comparison:\")\n","    print(f\"   Clean customers (n={len(clean_scores):,}):\")\n","    print(f\"      Mean: {clean_scores.mean():.3f}, Median: {clean_scores.median():.3f}, Std: {clean_scores.std():.3f}\")\n","    print(f\"   Suspicious customers (n={len(susp_scores):,}):\")\n","    print(f\"      Mean: {susp_scores.mean():.3f}, Median: {susp_scores.median():.3f}, Std: {susp_scores.std():.3f}\")\n","    print(f\"   Difference in means: {susp_scores.mean() - clean_scores.mean():.3f}\")\n","\n","    if susp_scores.mean() > clean_scores.mean():\n","        print(f\"   Suspicious customers have higher risk scores on average\")\n","    else:\n","        print(f\"   WARNING: Suspicious customers have LOWER risk scores - model may be inverted!\")\n","\n","    # Finding where known suspicious customers rank\n","    known_suspicious = results_df[results_df['actual_label'] == 1].copy()\n","    if len(known_suspicious) > 0:\n","        suspicious_ranks = known_suspicious.index.values\n","        avg_rank = suspicious_ranks.mean()\n","        avg_percentile = (avg_rank / len(results_df)) * 100\n","        top_1_pct_captured = (suspicious_ranks < len(results_df) * 0.01).sum()\n","        top_5_pct_captured = (suspicious_ranks < len(results_df) * 0.05).sum()\n","        top_10_pct_captured = (suspicious_ranks < len(results_df) * 0.10).sum()\n","\n","        print(f\"\\